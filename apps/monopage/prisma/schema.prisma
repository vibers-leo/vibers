// monopage.kr Prisma 스키마 — 아티스트 바이오 프로필 플랫폼
// 자체 PostgreSQL (vibers_main) — 멀티테넌트 (arthyun, art-way 등)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// 전시 테이블
model exhibitions {
  id             Int       @id @default(autoincrement())
  site_slug      String    @default("arthyun")
  title          String
  subtitle       String?
  artist         String?
  category       String?
  categories     String[]  @default([])
  poster_url     String?
  description    String?
  start_date     String?
  end_date       String?
  is_active      Boolean   @default(true)
  is_visible     Boolean   @default(true)
  is_main_slider Boolean   @default(false)
  youtube_url    String?
  sort_order     Int       @default(0)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now()) @updatedAt

  @@index([site_slug])
}

// 보도자료 테이블
model media_releases {
  id             Int       @id @default(autoincrement())
  site_slug      String    @default("arthyun")
  title          String
  content        String?
  press_name     String?
  source         String?
  source_url     String?
  link_url       String?
  image_url      String?
  published_date String?
  published_at   DateTime?
  is_visible     Boolean   @default(true)
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now()) @updatedAt

  @@index([site_slug])
}

// 메인 배너 테이블
model main_banner {
  id          Int       @id @default(autoincrement())
  site_slug   String    @default("arthyun")
  title       String?
  image_url   String?
  link_url    String?
  is_active   Boolean   @default(true)
  sort_order  Int       @default(0)
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt

  @@index([site_slug])
}

// 문의 테이블
model inquiries {
  id          Int       @id @default(autoincrement())
  site_slug   String    @default("arthyun")
  type        String    @default("general")
  name        String
  phone       String?
  email       String?
  content     String?
  status      String    @default("new")
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt

  @@index([site_slug])
}

// 일별 통계 테이블
model daily_stats {
  id          Int       @id @default(autoincrement())
  site_slug   String    @default("arthyun")
  date        String
  count       Int       @default(0)
  visitors    Int       @default(0)
  created_at  DateTime  @default(now())

  @@unique([site_slug, date])
}

// 사이트 설정 테이블 — site_slug를 고유키로 사용
model site_settings {
  id               Int       @id @default(autoincrement())
  site_slug        String    @unique
  site_name        String?
  site_title       String?
  site_description String?
  template         String    @default("arthyun")
  og_description   String?
  og_image_url     String?
  domain           String?
  logo_url         String?
  footer_logo_url  String?
  address          String?
  phone            String?
  email            String?
  instagram_url    String?
  blog_url         String?
  youtube_url      String?
  is_active        Boolean   @default(true)
  // monopage.kr 확장 필드
  bio              String?                        // 한 줄 소개 (바이오 프로필)
  theme_config     Json?                          // { font, bgColor, buttonStyle, accentColor }
  youtube_channel_id String?                      // 유튜브 채널 ID (간편 설정)
  show_instagram   Boolean   @default(true)       // 인스타 피드 노출 토글
  show_youtube     Boolean   @default(true)       // 유튜브 피드 노출 토글
  show_support     Boolean   @default(true)       // 후원 섹션 노출 토글
  pinned_feed_id   String?                        // 최상단 고정 피드 ID
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt
}

// 작품 판매 테이블
model Artwork {
  id          String   @id @default(uuid()) @db.Uuid
  site_slug   String
  title       String
  description String?
  price       Int
  currency    String   @default("KRW")
  image_url   String
  is_sold     Boolean  @default(false)
  is_active   Boolean  @default(true)
  buyer_email String?
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  @@index([site_slug])
}

// 작품 거래 내역 테이블
model ArtTransaction {
  id              String    @id @default(uuid()) @db.Uuid
  artwork_id      String
  site_slug       String
  buyer_email     String
  buyer_name      String?
  amount          Int
  commission      Int                              // 결제 원가 (PG 수수료)
  platform_share  Int       @default(0)            // 플랫폼 쉐어 (아티스트 설정 비율)
  artist_payout   Int                              // 아티스트 최종 정산액
  share_ratio     Int       @default(10)           // 당시 적용된 쉐어 비율 스냅샷 (%)
  status          String    @default("pending")
  payment_id      String?
  paid_at         DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz

  @@index([site_slug])
  @@index([artwork_id])
}

// 포트폴리오 테이블
model Portfolio {
  id              String   @id @default(uuid()) @db.Uuid
  site_slug       String   @default("arthyun")
  title           String
  client          String?
  description     String?
  image_url       String?
  category        String?
  categories      String[] @default([])
  completion_date String?
  is_featured     Boolean  @default(false)
  is_visible      Boolean  @default(true)
  sort_order      Int      @default(0)
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  @@index([site_slug])
}

// 인스타그램 연동
model InstagramConnection {
  id            String    @id @default(uuid()) @db.Uuid
  site_slug     String    @unique
  access_token  String
  user_id       String
  username      String
  token_expires DateTime  @db.Timestamptz
  last_synced   DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz
}

// 번역 캐시
model Translation {
  id          String   @id @default(uuid()) @db.Uuid
  site_slug   String
  source_text String
  source_lang String   @default("ko")
  target_lang String
  translated  String
  created_at  DateTime @default(now()) @db.Timestamptz

  @@unique([site_slug, source_text, target_lang])
  @@index([site_slug])
}

// ─────────────────────────────────────────────
// monopage.kr 신규 테이블
// ─────────────────────────────────────────────

// 바이오 프로필 링크 버튼
model ProfileLink {
  id          String   @id @default(uuid()) @db.Uuid
  site_slug   String
  title       String
  url         String
  icon        String?                              // lucide 아이콘명 또는 커스텀 이미지 URL
  sort_order  Int      @default(0)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  @@index([site_slug])
}

// 자율 수수료/구독 설정 — The Value Setting
model ValueSettings {
  id                  String   @id @default(uuid()) @db.Uuid
  site_slug           String   @unique
  subscription_fee    Int      @default(0)          // 월 자율 구독료 (원)
  revenue_share_ratio Int      @default(10)         // 판매/후원 시 플랫폼 쉐어 (0~100%)
  created_at          DateTime @default(now()) @db.Timestamptz
  updated_at          DateTime @updatedAt @db.Timestamptz
}

// 후원 기록
model Support {
  id              String    @id @default(uuid()) @db.Uuid
  site_slug       String
  supporter_name  String?
  supporter_email String?
  amount          Int                               // 총 후원금
  platform_fee    Int       @default(0)             // PG 수수료 (결제 원가)
  platform_share  Int       @default(0)             // 플랫폼 몫 (쉐어 비율 적용)
  artist_amount   Int       @default(0)             // 아티스트 몫
  message         String?                           // 응원 메시지 (방명록)
  is_public       Boolean   @default(true)          // 메시지 공개 여부
  payment_id      String?
  status          String    @default("pending")     // pending, completed, refunded
  paid_at         DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz

  @@index([site_slug])
}

// 유튜브 채널 연동
model YouTubeConnection {
  id            String    @id @default(uuid()) @db.Uuid
  site_slug     String    @unique
  channel_id    String
  channel_title String?
  thumbnail_url String?
  is_active     Boolean   @default(true)
  last_synced   DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz
}

// 실험 아카이브 기록
model ExperimentLog {
  id          String   @id @default(uuid()) @db.Uuid
  type        String                                // milestone, support_chain, artwork_donation, stat_snapshot
  title       String
  description String?
  metadata    Json?                                 // 유동적인 추가 데이터
  created_at  DateTime @default(now()) @db.Timestamptz
}
