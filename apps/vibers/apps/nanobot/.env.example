# =====================================
# Telegram Bot
# =====================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# =====================================
# Gemini API
# =====================================
SHARED_API_KEY=your_shared_gemini_api_key_here
GEMINI_API_MODEL=gemini-2.0-flash-exp

# =====================================
# 암호화 & 보안
# =====================================
ENCRYPTION_KEY=your_32_character_hex_key_here1234567890ab

# =====================================
# Rate Limiting
# =====================================
FREE_CREDITS_PER_USER=5
FREE_CREDITS_POOL_TOTAL=50
DAILY_LIMIT_PER_USER=10

# =====================================
# 운영
# =====================================
NODE_ENV=production
LOG_LEVEL=info
ADMIN_TELEGRAM_ID=123456789
