# Vibers Relay Server - Environment Variables

# WebSocket Server Port
# Default: 3457
PORT=3457

# Health Check Port (automatically PORT + 1)
# Default: 3458
# HEALTH_PORT=3458

# Authentication Token (optional but recommended)
# Set to enable token-based authentication on handshake
# When set, all clients must include { token: "..." } in their handshake message
# RELAY_AUTH_TOKEN=your-secret-token-here
