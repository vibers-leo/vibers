'use client';

import { useEffect, useState } from 'react';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import Image from 'next/image';
import type { UserSubscription, ServicePlan } from '@/lib/subscription/types';
import {
  generateSavingsTips,
  calculateTotalSavings,
  groupTipsByPriority,
  type SavingTip,
  type TipType,
} from '@/lib/subscription/savings-tips';

interface SubscriptionTipsProps {
  subscriptions: UserSubscription[];
  servicePlans: ServicePlan[];
}

export function SubscriptionTips({ subscriptions, servicePlans }: SubscriptionTipsProps) {
  const [tips, setTips] = useState<SavingTip[]>([]);
  const [loading, setLoading] = useState(true);
  const [showAll, setShowAll] = useState(false);

  useEffect(() => {
    async function loadTips() {
      setLoading(true);
      try {
        const generatedTips = await generateSavingsTips(subscriptions, servicePlans);
        setTips(generatedTips);
      } catch (error) {
        console.error('[Tips] Failed to generate tips:', error);
      } finally {
        setLoading(false);
      }
    }

    if (subscriptions.length > 0) {
      loadTips();
    } else {
      setLoading(false);
    }
  }, [subscriptions, servicePlans]);

  const totalSavings = calculateTotalSavings(tips);
  const { high, medium, low } = groupTipsByPriority(tips);
  const displayTips = showAll ? tips : tips.slice(0, 5);

  const getTipBadgeColor = (priority: number) => {
    if (priority >= 8) {
      return 'bg-red-500/10 text-red-600 border-red-500/20';
    } else if (priority >= 5) {
      return 'bg-yellow-500/10 text-yellow-600 border-yellow-500/20';
    }
    return 'bg-gray-500/10 text-gray-600 border-gray-500/20';
  };

  const getPriorityLabel = (priority: number) => {
    if (priority >= 8) return '높음';
    if (priority >= 5) return '중간';
    return '낮음';
  };

  if (loading) {
    return (
      <Card className="bg-gradient-to-br from-brand/5 to-brand-200/10 border-brand/30">
        <CardContent className="py-12">
          <div className="flex items-center justify-center gap-2 text-gray-600">
            <Image
              src="/icons/세모폰 기본.png"
              alt="로딩"
              width={40}
              height={40}
              className="animate-pulse"
            />
            <span>절약 팁 분석 중...</span>
          </div>
        </CardContent>
      </Card>
    );
  }

  if (tips.length === 0) {
    return (
      <Card className="bg-white border-brand/20 shadow-soft">
        <CardHeader>
          <CardTitle className="flex items-center gap-2 text-dark">
            <Image src="/icons/전구.png" alt="팁" width={24} height={24} />
            절약 팁
          </CardTitle>
        </CardHeader>
        <CardContent>
          <div className="text-center py-8">
            <Image
              src="/icons/세모폰 기본.png"
              alt="팁 없음"
              width={80}
              height={80}
              className="mx-auto mb-3 opacity-50"
            />
            <p className="text-gray-600 text-sm">
              현재 제안할 절약 팁이 없습니다.
            </p>
            <p className="text-gray-500 text-xs mt-2">
              구독을 더 추가하면 맞춤 절약 팁을 받아볼 수 있어요!
            </p>
          </div>
        </CardContent>
      </Card>
    );
  }

  return (
    <Card className="bg-gradient-to-br from-brand/5 to-brand-200/10 border-brand/30 shadow-brand">
      <CardHeader>
        <div className="flex items-center justify-between">
          <CardTitle className="flex items-center gap-2 text-dark">
            <Image src="/icons/전구.png" alt="절약 팁" width={24} height={24} />
            절약 팁
          </CardTitle>
          <Badge
            variant="outline"
            className="bg-brand text-dark border-brand/50 text-sm font-bold px-3 py-1"
          >
            최대 ₩{totalSavings.toLocaleString('ko-KR', { maximumFractionDigits: 0 })} 절감 가능
          </Badge>
        </div>
        <p className="text-sm text-gray-600 mt-2">
          {high.length > 0 && `🔥 우선순위 높음 ${high.length}개`}
          {medium.length > 0 && ` · 중간 ${medium.length}개`}
          {low.length > 0 && ` · 낮음 ${low.length}개`}
        </p>
      </CardHeader>

      <CardContent className="space-y-3">
        {displayTips.map((tip) => (
          <div
            key={tip.id}
            className="p-4 rounded-lg bg-white border border-brand/20 hover:border-brand/50 hover:shadow-soft transition-all group"
          >
            <div className="flex items-start gap-3">
              <div className="mt-1">
                <Image src="/icons/전구.png" alt="팁" width={20} height={20} />
              </div>

              <div className="flex-1 space-y-2">
                <div className="flex items-start justify-between gap-2">
                  <h4 className="font-semibold text-dark group-hover:text-brand-700 transition-colors line-clamp-2 flex-1">
                    {tip.title}
                  </h4>
                  <Badge
                    variant="outline"
                    className={`${getTipBadgeColor(tip.priority)} shrink-0`}
                  >
                    {getPriorityLabel(tip.priority)}
                  </Badge>
                </div>

                <p className="text-sm text-gray-600 leading-relaxed line-clamp-3">
                  {tip.description}
                </p>

                <div className="flex items-center justify-between pt-2 flex-wrap gap-2">
                  <div className="flex items-center gap-2">
                    <span className="text-sm font-medium text-green-600">
                      연간 절감액:
                    </span>
                    <span className="text-lg font-bold text-green-600 truncate">
                      ₩{tip.potentialSavings.toLocaleString('ko-KR', { maximumFractionDigits: 0 })}
                    </span>
                  </div>

                  {tip.actionUrl && (
                    <Button
                      variant="ghost"
                      size="sm"
                      className="text-brand-700 hover:text-brand hover:bg-brand/10"
                      asChild
                    >
                      <a href={tip.actionUrl} target="_blank" rel="noopener noreferrer">
                        자세히 보기
                        <Image src="/icons/화살표.png" alt="링크" width={12} height={12} className="ml-1" />
                      </a>
                    </Button>
                  )}
                </div>

                {tip.metadata && (
                  <div className="pt-2 border-t border-brand/10 space-y-1">
                    {tip.metadata.monthlyToYearly && (
                      <div className="flex items-center gap-4 text-xs text-gray-500 flex-wrap">
                        <span className="truncate">
                          월간: ₩{tip.metadata.monthlyToYearly.monthly.toLocaleString()}
                        </span>
                        <span>→</span>
                        <span className="text-green-600 truncate">
                          연간: ₩{tip.metadata.monthlyToYearly.yearly.toLocaleString()}
                        </span>
                      </div>
                    )}

                    {tip.metadata.duplicates && (
                      <div className="text-xs text-gray-500 truncate">
                        중복 서비스: {tip.metadata.duplicates.join(', ')}
                      </div>
                    )}

                    {tip.metadata.alternative && (
                      <div className="text-xs text-gray-500 truncate">
                        대체 서비스: {tip.metadata.alternative.name} (월 ₩
                        {tip.metadata.alternative.price.toLocaleString()})
                      </div>
                    )}
                  </div>
                )}
              </div>
            </div>
          </div>
        ))}

        {tips.length > 5 && !showAll && (
          <Button
            variant="outline"
            className="w-full border-brand/30 hover:bg-brand/10 hover:border-brand/50"
            onClick={() => setShowAll(true)}
          >
            {tips.length - 5}개 팁 더 보기
          </Button>
        )}

        {showAll && tips.length > 5 && (
          <Button
            variant="outline"
            className="w-full border-brand/30 hover:bg-brand/10"
            onClick={() => setShowAll(false)}
          >
            접기
          </Button>
        )}
      </CardContent>
    </Card>
  );
}
