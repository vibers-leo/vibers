'use client';

import { useState, useMemo } from 'react';
import { Calendar } from '@/components/ui/calendar';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { isSameDay, parseISO, format, startOfMonth, endOfMonth, eachDayOfInterval } from 'date-fns';
import { ko } from 'date-fns/locale';
import Image from 'next/image';
import type { UserSubscription } from '@/lib/subscription/types';
import { SubscriptionCard } from './subscription-card';
import { generateRecurringDates, getSubscriptionsForDate } from '@/lib/subscription/calendar';

interface SubscriptionCalendarProps {
  subscriptions: UserSubscription[];
  onEdit?: (subscription: UserSubscription) => void;
  onDelete?: (id: string) => void;
}

export function SubscriptionCalendar({
  subscriptions,
  onEdit,
  onDelete,
}: SubscriptionCalendarProps) {
  const [selectedDate, setSelectedDate] = useState<Date | undefined>(new Date());
  const [viewMonth, setViewMonth] = useState<Date>(new Date());

  // Generate recurring dates for the current view month
  const recurringDates = useMemo(
    () => generateRecurringDates(subscriptions, viewMonth),
    [subscriptions, viewMonth]
  );

  // Get all renewal dates for calendar markers
  const renewalDates = recurringDates.map(rd => rd.date);

  // Find subscriptions for selected date
  const selectedDateData = selectedDate
    ? getSubscriptionsForDate(selectedDate, recurringDates)
    : null;

  const subscriptionsForDate = selectedDateData?.subscriptions || [];

  // Calculate monthly total for selected month
  const getMonthlyTotal = () => {
    return recurringDates.reduce((sum, rd) => sum + rd.totalAmount, 0);
  };

  const formatCurrency = (amount: number) => {
    return new Intl.NumberFormat('ko-KR', {
      style: 'currency',
      currency: 'KRW',
      minimumFractionDigits: 0,
    }).format(amount);
  };

  return (
    <div className="grid lg:grid-cols-2 gap-6">
      {/* Calendar Section */}
      <Card className="bg-white border-brand/20 shadow-soft">
        <CardHeader>
          <CardTitle className="flex items-center gap-2 text-dark">
            <Image src="/icons/캘린더.png" alt="캘린더" width={24} height={24} />
            갱신 캘린더
          </CardTitle>
        </CardHeader>
        <CardContent>
          <Calendar
            mode="single"
            selected={selectedDate}
            onSelect={setSelectedDate}
            onMonthChange={setViewMonth}
            locale={ko}
            modifiers={{
              renewal: renewalDates,
            }}
            modifiersClassNames={{
              renewal: "relative after:absolute after:bottom-1 after:left-1/2 after:-translate-x-1/2 after:w-1 after:h-1 after:bg-brand after:rounded-full font-semibold text-brand-700",
            }}
            className="rounded-md border-brand/20"
          />

          {/* Month Summary */}
          <div className="mt-4 p-4 bg-warm rounded-lg border border-brand/20">
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-2">
                <Image src="/icons/동전.png" alt="비용" width={20} height={20} />
                <span className="text-sm text-gray-600">
                  {format(viewMonth, 'yyyy년 M월', { locale: ko })} 총 갱신 비용
                </span>
              </div>
              <span className="text-lg font-bold text-dark">
                {formatCurrency(getMonthlyTotal())}
              </span>
            </div>
            {recurringDates.length > 0 && (
              <div className="mt-2 text-xs text-gray-500 truncate">
                {recurringDates.length}개 결제일 · {subscriptions.filter(s => s.status === 'active').length}개 구독
              </div>
            )}
          </div>
        </CardContent>
      </Card>

      {/* Selected Date Details */}
      <div className="space-y-4">
        <Card className="bg-white border-brand/20 shadow-soft">
          <CardHeader>
            <CardTitle className="text-dark">
              {selectedDate
                ? format(selectedDate, 'yyyy년 M월 d일 (E)', { locale: ko })
                : '날짜를 선택하세요'}
            </CardTitle>
            <div className="flex items-center justify-between">
              <p className="text-sm text-gray-600">
                {subscriptionsForDate.length > 0
                  ? `${subscriptionsForDate.length}개의 구독 갱신 예정`
                  : '갱신 예정인 구독이 없습니다'}
              </p>
              {selectedDateData && selectedDateData.totalAmount > 0 && (
                <span className="text-lg font-bold text-brand-700">
                  {formatCurrency(selectedDateData.totalAmount)}
                </span>
              )}
            </div>
          </CardHeader>
        </Card>

        {/* Subscription Cards for Selected Date */}
        <div className="space-y-4">
          {subscriptionsForDate.length > 0 ? (
            subscriptionsForDate.map(subscription => (
              <SubscriptionCard
                key={subscription.id}
                subscription={subscription}
                onEdit={onEdit}
                onDelete={onDelete}
              />
            ))
          ) : (
            <Card className="bg-white/50 border-dashed border-brand/30">
              <CardContent className="py-12">
                <div className="text-center">
                  <Image
                    src="/icons/캘린더 앱.png"
                    alt="캘린더"
                    width={80}
                    height={80}
                    className="mx-auto mb-3 opacity-50"
                  />
                  <p className="text-gray-500 text-sm">
                    이 날짜에는 갱신 예정인 구독이 없습니다
                  </p>
                </div>
              </CardContent>
            </Card>
          )}
        </div>

        {/* Legend */}
        <Card className="bg-warm border-brand/10 shadow-soft">
          <CardContent className="py-4">
            <div className="flex items-center gap-2 text-xs text-gray-500">
              <div className="flex items-center gap-2">
                <div className="w-2 h-2 bg-brand rounded-full"></div>
                <span>갱신일</span>
              </div>
              <span className="text-gray-300">|</span>
              <div className="flex items-center gap-2">
                <div className="w-2 h-2 bg-gray-300 rounded-full"></div>
                <span>일반</span>
              </div>
            </div>
          </CardContent>
        </Card>
      </div>
    </div>
  );
}
