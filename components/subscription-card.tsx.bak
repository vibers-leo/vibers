'use client';

import { Card, CardContent, CardFooter, CardHeader } from '@/components/ui/card';
import { Badge } from '@/components/ui/badge';
import { Button } from '@/components/ui/button';
import Image from 'next/image';
import type { UserSubscription, PaymentMethodType } from '@/lib/subscription/types';
import { formatDistanceToNow } from 'date-fns';
import { ko } from 'date-fns/locale';

interface SubscriptionCardProps {
  subscription: UserSubscription;
  onEdit?: (subscription: UserSubscription) => void;
  onDelete?: (id: string) => void;
}

export function SubscriptionCard({ subscription, onEdit, onDelete }: SubscriptionCardProps) {
  const formatCurrency = (amount: number, currency: string) => {
    return new Intl.NumberFormat('ko-KR', {
      style: 'currency',
      currency: currency,
      minimumFractionDigits: 0,
    }).format(amount);
  };

  const getDaysUntilRenewal = () => {
    const today = new Date();
    const renewal = new Date(subscription.renewal_date);
    const diffTime = renewal.getTime() - today.getTime();
    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
    return diffDays;
  };

  const getStatusColor = (status: string) => {
    switch (status) {
      case 'active':
        return 'bg-green-500/10 text-green-600 border-green-500/20';
      case 'cancelled':
        return 'bg-red-500/10 text-red-600 border-red-500/20';
      case 'paused':
        return 'bg-yellow-500/10 text-yellow-600 border-yellow-500/20';
      case 'expired':
        return 'bg-gray-500/10 text-gray-600 border-gray-500/20';
      default:
        return 'bg-gray-500/10 text-gray-600 border-gray-500/20';
    }
  };

  const getStatusLabel = (status: string) => {
    switch (status) {
      case 'active':
        return '활성';
      case 'cancelled':
        return '취소됨';
      case 'paused':
        return '일시중지';
      case 'expired':
        return '만료됨';
      default:
        return status;
    }
  };

  const getBillingCycleLabel = (cycle: string) => {
    switch (cycle) {
      case 'monthly':
        return '월간';
      case 'yearly':
        return '연간';
      case 'lifetime':
        return '평생';
      default:
        return cycle;
    }
  };

  const getPaymentMethodLabel = (type: PaymentMethodType, cardLast4?: string) => {
    switch (type) {
      case 'credit_card':
        return cardLast4 ? `신용카드 ****${cardLast4}` : '신용카드';
      case 'debit_card':
        return cardLast4 ? `체크카드 ****${cardLast4}` : '체크카드';
      case 'bank_transfer':
        return '계좌이체';
      case 'paypal':
        return 'PayPal';
      case 'apple_pay':
        return 'Apple Pay';
      case 'google_pay':
        return 'Google Pay';
      case 'kakao_pay':
        return 'Kakao Pay';
      case 'naver_pay':
        return 'Naver Pay';
      case 'toss':
        return 'Toss';
      case 'other':
        return '기타';
      default:
        return type;
    }
  };

  const daysUntilRenewal = getDaysUntilRenewal();
  const serviceName = subscription.custom_service_name || subscription.service_plan?.service_name || '서비스';
  const planName = subscription.custom_plan_name || subscription.service_plan?.plan_name || '';

  return (
    <Card className="bg-white border-brand/20 hover:border-brand/50 hover:shadow-brand transition-all group">
      <CardHeader className="pb-3">
        <div className="flex items-start justify-between">
          <div className="flex-1">
            <div className="flex items-center gap-2 mb-1">
              <Image src="/icons/카드.png" alt="구독" width={20} height={20} />
              <h3 className="font-semibold text-dark text-lg line-clamp-1">
                {serviceName}
              </h3>
            </div>
            {planName && (
              <p className="text-sm text-gray-600 ml-7 line-clamp-1">
                {planName}
              </p>
            )}
          </div>

          <Badge
            variant="outline"
            className={`${getStatusColor(subscription.status)} shrink-0 ml-2`}
          >
            {getStatusLabel(subscription.status)}
          </Badge>
        </div>
      </CardHeader>

      <CardContent className="space-y-3 pb-3">
        {/* Price */}
        <div className="flex items-center justify-between p-3 bg-warm rounded-lg border border-brand/10">
          <div className="flex items-center gap-2">
            <Image src="/icons/동전.png" alt="가격" width={20} height={20} />
            <span className="text-sm text-gray-600">
              {getBillingCycleLabel(subscription.billing_cycle)}
            </span>
          </div>
          <span className="text-lg font-bold text-dark">
            {formatCurrency(subscription.price, subscription.currency)}
          </span>
        </div>

        {/* Renewal Date */}
        <div className="flex items-center justify-between p-3 bg-warm rounded-lg border border-brand/10">
          <div className="flex items-center gap-2">
            <Image src="/icons/캘린더.png" alt="갱신일" width={20} height={20} />
            <span className="text-sm text-gray-600">다음 갱신</span>
          </div>
          <div className="flex items-center gap-2">
            <span className="text-sm text-dark">
              {new Date(subscription.renewal_date).toLocaleDateString('ko-KR')}
            </span>
            {subscription.status === 'active' && daysUntilRenewal >= 0 && (
              <Badge
                variant="outline"
                className={`
                  ${daysUntilRenewal <= 7 ? 'bg-red-500/10 text-red-600 border-red-500/20' : 'bg-brand/10 text-dark border-brand/30'}
                `}
              >
                D-{daysUntilRenewal}
              </Badge>
            )}
          </div>
        </div>

        {/* Payment Method */}
        {subscription.payment_method && (
          <div className="flex items-center justify-between p-3 bg-warm rounded-lg border border-brand/10">
            <div className="flex items-center gap-2">
              <Image src="/icons/카드.png" alt="결제" width={20} height={20} />
              <span className="text-sm text-gray-600">결제 방법</span>
            </div>
            <span className="text-sm text-dark">
              {getPaymentMethodLabel(subscription.payment_method.type, subscription.payment_method.card_last4)}
            </span>
          </div>
        )}

        {/* Notes */}
        {subscription.notes && (
          <div className="text-xs text-gray-500 italic line-clamp-2 p-3 bg-warm/50 rounded-lg border border-brand/10">
            {subscription.notes}
          </div>
        )}
      </CardContent>

      <CardFooter className="pt-3 border-t border-brand/10 gap-2">
        <Button
          variant="outline"
          size="sm"
          className="flex-1 border-brand/30 hover:bg-brand/10 hover:border-brand/50"
          onClick={() => onEdit?.(subscription)}
        >
          <Image src="/icons/연필.png" alt="수정" width={16} height={16} className="mr-2" />
          수정
        </Button>
        <Button
          variant="outline"
          size="sm"
          className="flex-1 border-red-500/30 hover:bg-red-500/10 hover:border-red-500/50 hover:text-red-600"
          onClick={() => onDelete?.(subscription.id)}
        >
          <Image src="/icons/휴지통.png" alt="삭제" width={16} height={16} className="mr-2" />
          삭제
        </Button>
      </CardFooter>
    </Card>
  );
}
