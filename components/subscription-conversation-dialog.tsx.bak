'use client';

import { useState, useRef, useEffect } from 'react';
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogHeader,
  DialogTitle,
} from '@/components/ui/dialog';
import { Button } from '@/components/ui/Button';
import Image from 'next/image';
import { toast } from 'sonner';
import { createSubscription } from '@/lib/subscription/firestore';
import type { ParsedSubscription } from '@/lib/subscription/conversation-parser';

interface SubscriptionConversationDialogProps {
  open: boolean;
  onOpenChange: (open: boolean) => void;
  onComplete?: () => void;
}

interface Message {
  id: string;
  role: 'user' | 'assistant';
  content: string;
  timestamp: Date;
}

export function SubscriptionConversationDialog({
  open,
  onOpenChange,
  onComplete,
}: SubscriptionConversationDialogProps) {
  const [messages, setMessages] = useState<Message[]>([
    {
      id: '1',
      role: 'assistant',
      content:
        '안녕하세요! 사용하고 계신 구독 서비스를 편하게 말씀해주세요 😊\n\n예: "넷플릭스, 유튜브 프리미엄 사용해요"',
      timestamp: new Date(),
    },
  ]);
  const [input, setInput] = useState('');
  const [loading, setLoading] = useState(false);
  const [collectedSubscriptions, setCollectedSubscriptions] = useState<ParsedSubscription[]>([]);
  const messagesEndRef = useRef<HTMLDivElement>(null);

  const scrollToBottom = () => {
    messagesEndRef.current?.scrollIntoView({ behavior: 'smooth' });
  };

  useEffect(() => {
    scrollToBottom();
  }, [messages]);

  const handleSend = async () => {
    if (!input.trim() || loading) return;

    const userMessage: Message = {
      id: Date.now().toString(),
      role: 'user',
      content: input,
      timestamp: new Date(),
    };

    setMessages((prev) => [...prev, userMessage]);
    setInput('');
    setLoading(true);

    try {
      const response = await fetch('/api/subscriptions/conversation', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userMessage: input }),
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error(data.error || '오류가 발생했습니다');
      }

      // AI 응답 추가
      const aiMessage: Message = {
        id: (Date.now() + 1).toString(),
        role: 'assistant',
        content: data.message,
        timestamp: new Date(),
      };

      setMessages((prev) => [...prev, aiMessage]);

      // 파싱된 구독 추가
      if (data.parsedSubscriptions && data.parsedSubscriptions.length > 0) {
        setCollectedSubscriptions((prev) => [
          ...prev,
          ...data.parsedSubscriptions.filter(
            (newSub: ParsedSubscription) =>
              !prev.some((existing) => existing.serviceName === newSub.serviceName)
          ),
        ]);
      }

      // 대화 완료 처리
      if (data.readyToComplete && collectedSubscriptions.length > 0) {
        handleComplete();
      }
    } catch (error: any) {
      toast.error('오류 발생', { description: error.message });
    } finally {
      setLoading(false);
    }
  };

  const handleComplete = async () => {
    if (collectedSubscriptions.length === 0) {
      toast.error('구독 서비스를 먼저 추가해주세요');
      return;
    }

    setLoading(true);

    try {
      // 모든 수집된 구독을 Firestore에 저장
      for (const sub of collectedSubscriptions) {
        await createSubscription({
          custom_service_name: sub.serviceName,
          custom_plan_name: sub.planName || '기본',
          billing_cycle: 'monthly',
          price: 0, // 사용자가 나중에 수정
          currency: 'KRW',
          start_date: new Date().toISOString().split('T')[0],
          renewal_date: new Date(
            new Date().setMonth(new Date().getMonth() + 1)
          )
            .toISOString()
            .split('T')[0],
        });
      }

      toast.success(`${collectedSubscriptions.length}개 구독이 추가되었습니다!`);
      onComplete?.();
      onOpenChange(false);

      // 초기화
      setMessages([
        {
          id: '1',
          role: 'assistant',
          content:
            '안녕하세요! 사용하고 계신 구독 서비스를 편하게 말씀해주세요 😊\n\n예: "넷플릭스, 유튜브 프리미엄 사용해요"',
          timestamp: new Date(),
        },
      ]);
      setCollectedSubscriptions([]);
    } catch (error: any) {
      toast.error('오류 발생', { description: error.message });
    } finally {
      setLoading(false);
    }
  };

  return (
    <Dialog open={open} onOpenChange={onOpenChange}>
      <DialogContent className="bg-white border-brand/20 max-w-2xl max-h-[80vh] flex flex-col">
        <DialogHeader>
          <div className="flex items-center gap-3">
            <Image src="/icons/말풍선1.png" alt="AI 대화" width={32} height={32} />
            <div>
              <DialogTitle className="text-dark">AI와 대화하기</DialogTitle>
              <DialogDescription className="text-gray-600">
                편하게 구독 서비스를 말씀해주세요
              </DialogDescription>
            </div>
          </div>
        </DialogHeader>

        {/* 수집된 구독 목록 */}
        {collectedSubscriptions.length > 0 && (
          <div className="bg-brand/10 border border-brand/30 rounded-lg p-3">
            <p className="text-sm font-medium text-dark mb-2">
              수집된 구독 ({collectedSubscriptions.length}개):
            </p>
            <div className="flex flex-wrap gap-2">
              {collectedSubscriptions.map((sub, idx) => (
                <div
                  key={idx}
                  className="bg-brand text-dark px-3 py-1 rounded-full text-sm font-medium"
                >
                  {sub.serviceName}
                </div>
              ))}
            </div>
          </div>
        )}

        {/* 대화 내역 */}
        <div className="flex-1 overflow-y-auto space-y-4 pr-4">
          {messages.map((message) => (
            <div
              key={message.id}
              className={`flex ${message.role === 'user' ? 'justify-end' : 'justify-start'}`}
            >
              {message.role === 'assistant' && (
                <Image
                  src="/icons/세모폰 기본.png"
                  alt="세모"
                  width={32}
                  height={32}
                  className="mr-2 flex-shrink-0"
                />
              )}
              <div
                className={`max-w-[70%] rounded-2xl px-4 py-3 ${
                  message.role === 'user'
                    ? 'bg-brand text-dark'
                    : 'bg-warm border border-brand/10 text-dark'
                }`}
              >
                <p className="text-sm whitespace-pre-wrap">{message.content}</p>
                <p className="text-xs mt-1 opacity-60">
                  {message.timestamp.toLocaleTimeString('ko-KR', {
                    hour: '2-digit',
                    minute: '2-digit',
                  })}
                </p>
              </div>
            </div>
          ))}
          {loading && (
            <div className="flex justify-start">
              <Image
                src="/icons/세모폰 기본.png"
                alt="세모"
                width={32}
                height={32}
                className="mr-2 animate-pulse"
              />
              <div className="bg-warm border border-brand/10 rounded-2xl px-4 py-3">
                <p className="text-sm text-gray-600">생각하는 중...</p>
              </div>
            </div>
          )}
          <div ref={messagesEndRef} />
        </div>

        {/* 입력 영역 */}
        <div className="flex gap-2 pt-4 border-t border-brand/10">
          <input
            type="text"
            value={input}
            onChange={(e) => setInput(e.target.value)}
            onKeyPress={(e) => {
              if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                handleSend();
              }
            }}
            placeholder="예: 넷플릭스, 유튜브 사용해요"
            className="flex-1 px-4 py-3 bg-warm border-2 border-brand/20 rounded-xl focus:outline-none focus:border-brand focus:ring-2 focus:ring-brand/20 disabled:opacity-50 disabled:cursor-not-allowed text-dark placeholder:text-gray-400"
            disabled={loading}
          />
          <Button
            variant="primary"
            size="lg"
            onClick={handleSend}
            disabled={loading || !input.trim()}
          >
            전송
          </Button>
        </div>

        {/* 완료 버튼 */}
        {collectedSubscriptions.length > 0 && (
          <Button
            variant="secondary"
            size="lg"
            onClick={handleComplete}
            disabled={loading}
            fullWidth
          >
            {collectedSubscriptions.length}개 구독 추가하기
          </Button>
        )}
      </DialogContent>
    </Dialog>
  );
}
