'use client';

import { useMemo } from 'react';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import Image from 'next/image';
import {
  PieChart,
  Pie,
  Cell,
  ResponsiveContainer,
  Legend,
  Tooltip,
  BarChart,
  Bar,
  XAxis,
  YAxis,
  CartesianGrid,
  LineChart,
  Line,
} from 'recharts';
import type { UserSubscription } from '@/lib/subscription/types';
import { addMonths, format } from 'date-fns';
import { ko } from 'date-fns/locale';

interface SubscriptionAnalyticsProps {
  subscriptions: UserSubscription[];
}

const COLORS = [
  '#FEE500', // brand yellow
  '#FDD835', // brand-600
  '#E5C100', // brand-700
  '#10b981', // emerald
  '#3b82f6', // blue
  '#ec4899', // pink
  '#f59e0b', // amber
  '#ef4444', // red
  '#06b6d4', // cyan
  '#14b8a6', // teal
];

export function SubscriptionAnalytics({ subscriptions }: SubscriptionAnalyticsProps) {
  const activeSubscriptions = subscriptions.filter((s) => s.status === 'active');

  // 1. 서비스별 비용 분포 (파이 차트)
  const serviceDistribution = useMemo(() => {
    const serviceMap = new Map<string, { name: string; value: number; count: number }>();

    activeSubscriptions.forEach((sub) => {
      const name = sub.custom_service_name || sub.service_plan?.service_name || '기타';
      const monthlyPrice = sub.billing_cycle === 'yearly' ? sub.price / 12 : sub.price;

      if (serviceMap.has(name)) {
        const existing = serviceMap.get(name)!;
        existing.value += monthlyPrice;
        existing.count += 1;
      } else {
        serviceMap.set(name, { name, value: monthlyPrice, count: 1 });
      }
    });

    return Array.from(serviceMap.values())
      .sort((a, b) => b.value - a.value)
      .slice(0, 10); // Top 10만 표시
  }, [activeSubscriptions]);

  // 2. 결제 주기별 비교 (바 차트)
  const billingCycleData = useMemo(() => {
    const cycles = {
      monthly: { cycle: '월간', count: 0, cost: 0, avgCost: 0 },
      yearly: { cycle: '연간', count: 0, cost: 0, avgCost: 0 },
      lifetime: { cycle: '평생', count: 0, cost: 0, avgCost: 0 },
    };

    activeSubscriptions.forEach((sub) => {
      const data = cycles[sub.billing_cycle];
      if (data) {
        data.count += 1;
        data.cost += sub.price;
      }
    });

    // 평균 계산
    Object.values(cycles).forEach((data) => {
      if (data.count > 0) {
        data.avgCost = Math.round(data.cost / data.count);
      }
    });

    return Object.values(cycles).filter((c) => c.count > 0);
  }, [activeSubscriptions]);

  // 3. 향후 12개월 지출 예상 (라인 차트)
  const monthlyTrend = useMemo(() => {
    const today = new Date();
    const trend: { month: string; cost: number; subscriptions: number }[] = [];

    for (let i = 0; i < 12; i++) {
      const targetMonth = addMonths(today, i);
      const monthKey = format(targetMonth, 'yyyy-MM');
      const monthLabel = format(targetMonth, 'M월', { locale: ko });

      let monthlyCost = 0;
      let subsCount = 0;

      activeSubscriptions.forEach((sub) => {
        // 월간 구독
        if (sub.billing_cycle === 'monthly') {
          monthlyCost += sub.price;
          subsCount += 1;
        }
        // 연간 구독 (해당 월에 갱신되는지 확인)
        else if (sub.billing_cycle === 'yearly') {
          const renewalDate = new Date(sub.renewal_date);
          const renewalMonth = format(renewalDate, 'yyyy-MM');

          // 매년 같은 월에 갱신
          if (renewalMonth === monthKey || targetMonth.getMonth() === renewalDate.getMonth()) {
            monthlyCost += sub.price;
            subsCount += 1;
          }
        }
      });

      trend.push({
        month: monthLabel,
        cost: Math.round(monthlyCost),
        subscriptions: subsCount,
      });
    }

    return trend;
  }, [activeSubscriptions]);

  const formatCurrency = (value: number) => {
    return `₩${value.toLocaleString('ko-KR', { maximumFractionDigits: 0 })}`;
  };

  if (activeSubscriptions.length === 0) {
    return (
      <Card className="bg-white border-brand/20 shadow-soft">
        <CardContent className="py-20">
          <div className="text-center">
            <Image
              src="/icons/차트2.png"
              alt="분석"
              width={80}
              height={80}
              className="mx-auto mb-3 opacity-50"
            />
            <p className="text-gray-600 text-sm">
              활성 구독이 없어 분석할 데이터가 없습니다.
            </p>
          </div>
        </CardContent>
      </Card>
    );
  }

  return (
    <div className="space-y-6">
      {/* 상단 요약 */}
      <div className="grid gap-4 md:grid-cols-3">
        <Card className="bg-gradient-to-br from-brand/10 to-brand-200/20 border-brand/30 shadow-soft">
          <CardHeader className="pb-3">
            <CardTitle className="text-sm font-medium text-gray-600">
              월간 평균 지출
            </CardTitle>
          </CardHeader>
          <CardContent>
            <div className="text-2xl font-bold text-dark">
              {formatCurrency(
                activeSubscriptions.reduce((sum, sub) => {
                  return sum + (sub.billing_cycle === 'yearly' ? sub.price / 12 : sub.price);
                }, 0)
              )}
            </div>
            <p className="text-xs text-gray-500 mt-1">
              {activeSubscriptions.length}개 구독 기준
            </p>
          </CardContent>
        </Card>

        <Card className="bg-gradient-to-br from-green-500/10 to-emerald-500/20 border-green-500/30 shadow-soft">
          <CardHeader className="pb-3">
            <CardTitle className="text-sm font-medium text-gray-600">
              가장 비싼 구독
            </CardTitle>
          </CardHeader>
          <CardContent>
            <div className="text-2xl font-bold text-dark">
              {(() => {
                const mostExpensive = [...activeSubscriptions].sort((a, b) => {
                  const priceA = a.billing_cycle === 'yearly' ? a.price / 12 : a.price;
                  const priceB = b.billing_cycle === 'yearly' ? b.price / 12 : b.price;
                  return priceB - priceA;
                })[0];

                if (!mostExpensive) return '-';

                return formatCurrency(
                  mostExpensive.billing_cycle === 'yearly'
                    ? mostExpensive.price / 12
                    : mostExpensive.price
                );
              })()}
            </div>
            <p className="text-xs text-gray-500 mt-1 truncate">
              {(() => {
                const mostExpensive = [...activeSubscriptions].sort((a, b) => {
                  const priceA = a.billing_cycle === 'yearly' ? a.price / 12 : a.price;
                  const priceB = b.billing_cycle === 'yearly' ? b.price / 12 : b.price;
                  return priceB - priceA;
                })[0];

                return (
                  mostExpensive?.custom_service_name ||
                  mostExpensive?.service_plan?.service_name ||
                  '-'
                );
              })()}
            </p>
          </CardContent>
        </Card>

        <Card className="bg-gradient-to-br from-orange-500/10 to-amber-500/20 border-orange-500/30 shadow-soft">
          <CardHeader className="pb-3">
            <CardTitle className="text-sm font-medium text-gray-600">
              다음 달 예상 지출
            </CardTitle>
          </CardHeader>
          <CardContent>
            <div className="text-2xl font-bold text-dark">
              {formatCurrency(monthlyTrend[1]?.cost || 0)}
            </div>
            <p className="text-xs text-gray-500 mt-1">
              {monthlyTrend[1]?.subscriptions || 0}개 구독 예정
            </p>
          </CardContent>
        </Card>
      </div>

      {/* 차트 섹션 */}
      <div className="grid lg:grid-cols-2 gap-6">
        {/* 서비스별 비용 분포 (파이 차트) */}
        <Card className="bg-white border-brand/20 shadow-soft">
          <CardHeader>
            <CardTitle className="flex items-center gap-2 text-dark">
              <Image src="/icons/차트.png" alt="차트" width={24} height={24} />
              서비스별 비용 분포
            </CardTitle>
            <p className="text-xs text-gray-500 mt-1">월간 비용 기준 상위 10개</p>
          </CardHeader>
          <CardContent>
            <ResponsiveContainer width="100%" height={300}>
              <PieChart>
                <Pie
                  data={serviceDistribution}
                  cx="50%"
                  cy="50%"
                  labelLine={false}
                  label={(entry: any) => {
                    const name = entry.name.length > 8 ? entry.name.substring(0, 8) + '...' : entry.name;
                    return `${name}`;
                  }}
                  outerRadius={80}
                  fill="#8884d8"
                  dataKey="value"
                >
                  {serviceDistribution.map((entry, index) => (
                    <Cell key={`cell-${index}`} fill={COLORS[index % COLORS.length]} />
                  ))}
                </Pie>
                <Tooltip
                  formatter={(value: number | undefined) => formatCurrency(value || 0)}
                  contentStyle={{
                    backgroundColor: '#fff',
                    border: '1px solid rgba(254, 229, 0, 0.2)',
                    borderRadius: '12px',
                  }}
                  labelStyle={{ color: '#1A1A1A' }}
                />
                <Legend
                  wrapperStyle={{ fontSize: '12px' }}
                  formatter={(value, entry: any) =>
                    `${value}: ${formatCurrency(entry.payload.value)}`
                  }
                />
              </PieChart>
            </ResponsiveContainer>
          </CardContent>
        </Card>

        {/* 결제 주기별 비교 (바 차트) */}
        <Card className="bg-white border-brand/20 shadow-soft">
          <CardHeader>
            <CardTitle className="flex items-center gap-2 text-dark">
              <Image src="/icons/차트2.png" alt="분석" width={24} height={24} />
              결제 주기별 비교
            </CardTitle>
            <p className="text-xs text-gray-500 mt-1">평균 비용 및 구독 수</p>
          </CardHeader>
          <CardContent>
            <ResponsiveContainer width="100%" height={300}>
              <BarChart data={billingCycleData}>
                <CartesianGrid strokeDasharray="3 3" stroke="rgba(0,0,0,0.1)" />
                <XAxis
                  dataKey="cycle"
                  stroke="#666"
                  style={{ fontSize: '12px' }}
                />
                <YAxis stroke="#666" style={{ fontSize: '12px' }} />
                <Tooltip
                  formatter={(value: number | undefined, name: string | undefined) => {
                    if (name === 'avgCost') return [formatCurrency(value || 0), '평균 비용'];
                    return [value || 0, '구독 수'];
                  }}
                  contentStyle={{
                    backgroundColor: '#fff',
                    border: '1px solid rgba(254, 229, 0, 0.2)',
                    borderRadius: '12px',
                  }}
                  labelStyle={{ color: '#1A1A1A' }}
                />
                <Legend
                  wrapperStyle={{ fontSize: '12px' }}
                  formatter={(value) =>
                    value === 'count' ? '구독 수' : value === 'avgCost' ? '평균 비용' : value
                  }
                />
                <Bar dataKey="count" fill="#FEE500" name="구독 수" />
                <Bar dataKey="avgCost" fill="#10b981" name="평균 비용" />
              </BarChart>
            </ResponsiveContainer>
          </CardContent>
        </Card>
      </div>

      {/* 향후 12개월 지출 예상 (라인 차트) */}
      <Card className="bg-white border-brand/20 shadow-soft">
        <CardHeader>
          <CardTitle className="flex items-center gap-2 text-dark">
            <Image src="/icons/그래프.png" alt="추세" width={24} height={24} />
            향후 12개월 지출 예상
          </CardTitle>
          <p className="text-xs text-gray-500 mt-1">
            월간/연간 구독 기반 예측 (연간 구독은 갱신월에만 표시)
          </p>
        </CardHeader>
        <CardContent>
          <ResponsiveContainer width="100%" height={350}>
            <LineChart data={monthlyTrend}>
              <CartesianGrid strokeDasharray="3 3" stroke="rgba(0,0,0,0.1)" />
              <XAxis dataKey="month" stroke="#666" style={{ fontSize: '12px' }} />
              <YAxis stroke="#666" style={{ fontSize: '12px' }} />
              <Tooltip
                formatter={(value: number | undefined, name: string | undefined) => {
                  if (name === 'cost') return [formatCurrency(value || 0), '지출'];
                  return [value || 0, '구독 수'];
                }}
                contentStyle={{
                  backgroundColor: '#fff',
                  border: '1px solid rgba(254, 229, 0, 0.2)',
                  borderRadius: '12px',
                }}
                labelStyle={{ color: '#1A1A1A' }}
              />
              <Legend
                wrapperStyle={{ fontSize: '12px' }}
                formatter={(value) =>
                  value === 'cost' ? '예상 지출' : value === 'subscriptions' ? '구독 수' : value
                }
              />
              <Line
                type="monotone"
                dataKey="cost"
                stroke="#10b981"
                strokeWidth={2}
                dot={{ fill: '#10b981', r: 4 }}
                activeDot={{ r: 6 }}
                name="예상 지출"
              />
              <Line
                type="monotone"
                dataKey="subscriptions"
                stroke="#FEE500"
                strokeWidth={2}
                dot={{ fill: '#FEE500', r: 4 }}
                name="구독 수"
              />
            </LineChart>
          </ResponsiveContainer>

          <div className="mt-4 p-4 bg-warm rounded-lg border border-brand/20">
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
              <div>
                <div className="text-xs text-gray-500 mb-1">현재 월</div>
                <div className="text-lg font-bold text-dark">
                  {formatCurrency(monthlyTrend[0]?.cost || 0)}
                </div>
              </div>
              <div>
                <div className="text-xs text-gray-500 mb-1">3개월 평균</div>
                <div className="text-lg font-bold text-dark">
                  {formatCurrency(
                    Math.round(
                      monthlyTrend.slice(0, 3).reduce((sum, m) => sum + m.cost, 0) / 3
                    )
                  )}
                </div>
              </div>
              <div>
                <div className="text-xs text-gray-500 mb-1">6개월 평균</div>
                <div className="text-lg font-bold text-dark">
                  {formatCurrency(
                    Math.round(
                      monthlyTrend.slice(0, 6).reduce((sum, m) => sum + m.cost, 0) / 6
                    )
                  )}
                </div>
              </div>
              <div>
                <div className="text-xs text-gray-500 mb-1">12개월 총계</div>
                <div className="text-lg font-bold text-green-600">
                  {formatCurrency(monthlyTrend.reduce((sum, m) => sum + m.cost, 0))}
                </div>
              </div>
            </div>
          </div>
        </CardContent>
      </Card>
    </div>
  );
}
